---
import Layout from '../layouts/Layout.astro';
---

<Layout title="联系我 | AJMD">
  <section style="padding: 2rem 0; max-width:600px;">
    <h1>联系我</h1>
    <p style="color:#888; margin-bottom:2rem;">欢迎交流AI+财务的一切。</p>

    <div class="card" style="margin-bottom:1rem;">
      <p style="font-size:0.85rem; color:#555;">📕 小红书</p>
      <p style="font-size:1.1rem; color:#ff6b6b;">@卡戴珊玩财务</p>
      <p style="color:#888; font-size:0.9rem;">每日更新AI+财务提效技巧</p>
    </div>

    <div class="card" style="margin-bottom:1rem;">
      <p style="font-size:0.85rem; color:#555;">📧 邮箱</p>
      <p style="font-size:1.1rem; color:#ccc;">ajmd@ajmd.me</p>
      <p style="color:#888; font-size:0.9rem;">商务合作 / 咨询</p>
    </div>

    <div class="card" style="margin-bottom:1rem;">
      <p style="font-size:0.85rem; color:#555;">💬 微信</p>
      <p style="color:#888; font-size:0.9rem;">添加好友请备注"AI财务"</p>
    </div>

    <div style="margin-top:2rem; padding:1.5rem; background:#111; border:1px solid #1a1a1a; border-radius:8px;">
      <p style="color:#888; font-size:0.9rem; margin-bottom:0.5rem;">
        目前主要通过小红书更新内容。<br/>
        产品上线后会开通更多联系方式。
      </p>
    </div>
  </section>
</Layout>
