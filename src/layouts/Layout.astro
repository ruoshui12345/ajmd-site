---
export interface Props {
  title?: string;
  description?: string;
}

const { title = '李宗奇 | 财务×AI', description = '出纳出身，5年做到财务经理。专注AI+财务提效。' } = Astro.props;
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Noto+Sans+SC:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <style>
    :root {
      --bg: #0c0c0e;
      --bg-card: #151518;
      --bg-card-hover: #1c1c21;
      --border: #222226;
      --border-hover: #333338;
      --text: #f0f0f2;
      --text-secondary: #9b9ba3;
      --text-muted: #5c5c66;
      --accent: #6c8cff;
      --accent-glow: rgba(108, 140, 255, 0.1);
      --accent2: #ff6b6b;
      --radius: 12px;
      --radius-sm: 8px;
      --max-w: 1200px;
    }
    * { margin:0; padding:0; box-sizing:border-box; }
    html { scroll-behavior: smooth; }
    body {
      font-family: 'Inter', 'Noto Sans SC', -apple-system, sans-serif;
      background: var(--bg);
      color: var(--text);
      line-height: 1.7;
      -webkit-font-smoothing: antialiased;
    }

    .container { max-width: var(--max-w); margin: 0 auto; padding: 0 2rem; }

    /* ── Nav ── */
    nav {
      display: flex; justify-content: space-between; align-items: center;
      padding: 1.2rem 0; border-bottom: 1px solid var(--border);
      position: sticky; top: 0; z-index: 100;
      backdrop-filter: blur(20px); background: rgba(12,12,14,0.85);
    }
    .logo { font-weight: 700; font-size: 1.2rem; color: #fff; text-decoration: none; letter-spacing: -0.02em; }
    .logo span { color: var(--accent); }
    .nav-links { display: flex; gap: 2rem; }
    .nav-links a {
      color: var(--text-secondary); text-decoration: none; font-size: 0.85rem; font-weight: 500;
      padding: 0.4rem 0; transition: color 0.2s; position: relative;
    }
    .nav-links a:hover { color: #fff; }
    .nav-links a::after {
      content: ''; position: absolute; bottom: -1px; left: 0; width: 0; height: 2px;
      background: var(--accent); transition: width 0.3s;
    }
    .nav-links a:hover::after { width: 100%; }

    /* ── Sections ── */
    section { padding: 5rem 0; }
    .section-tag {
      display: inline-block; font-size: 0.75rem; font-weight: 600;
      text-transform: uppercase; letter-spacing: 0.12em; color: var(--accent);
      background: rgba(108,140,255,0.08); padding: 0.3rem 0.7rem;
      border-radius: 4px; margin-bottom: 0.8rem;
    }
    h1 { font-size: 3.5rem; font-weight: 800; line-height: 1.15; letter-spacing: -0.03em; margin-bottom: 1rem; }
    h1 .gradient { background: linear-gradient(135deg, var(--accent), var(--accent2)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
    h2 { font-size: 2.2rem; font-weight: 700; margin-bottom: 1rem; line-height: 1.3; }
    h3 { font-size: 1.15rem; font-weight: 600; margin-bottom: 0.5rem; color: #fff; }
    p { color: var(--text-secondary); font-size: 0.95rem; line-height: 1.8; margin-bottom: 0.8rem; }

    /* ── Hero ── */
    .hero { display: flex; align-items: center; gap: 4rem; padding: 4rem 0; }
    .hero-text { flex: 1; }
    .hero-image { flex: 0 0 320px; }
    .hero-image-placeholder {
      width: 320px; height: 380px; border-radius: var(--radius);
      background: linear-gradient(135deg, #1a1a20, #22222a);
      display: flex; align-items: center; justify-content: center;
      border: 1px solid var(--border); overflow: hidden;
    }
    .hero-image-placeholder .initials { font-size: 5rem; font-weight: 800; color: var(--accent); opacity: 0.3; }
    .hero-sub { font-size: 1.1rem; color: var(--text-muted); margin-bottom: 0.5rem; }
    .hero-title-line { display: flex; align-items: center; gap: 0.5rem; flex-wrap: wrap; }
    .hero-badge {
      display: inline-block; font-size: 0.7rem; font-weight: 600;
      padding: 0.2rem 0.6rem; border-radius: 20px;
      background: rgba(108,140,255,0.12); color: var(--accent);
      letter-spacing: 0.05em;
    }
    .social-links { display: flex; gap: 1rem; margin-top: 1.5rem; }
    .social-links a {
      display: flex; align-items: center; gap: 0.4rem;
      padding: 0.5rem 1rem; border-radius: 6px;
      border: 1px solid var(--border); color: var(--text-secondary);
      text-decoration: none; font-size: 0.85rem; transition: all 0.2s;
    }
    .social-links a:hover { border-color: var(--accent); color: var(--accent); background: rgba(108,140,255,0.05); }

    /* ── Cards ── */
    .card {
      background: var(--bg-card); border: 1px solid var(--border);
      border-radius: var(--radius); padding: 2rem;
      transition: all 0.25s;
    }
    .card:hover { border-color: var(--border-hover); background: var(--bg-card-hover); transform: translateY(-2px); }

    .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; }
    .grid-3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 1.5rem; }
    .grid-4 { display: grid; grid-template-columns: 1fr 1fr 1fr 1fr; gap: 1.5rem; }

    /* ── Section center ── */
    .section-center { text-align: center; }

    /* ── Tags ── */
    .tag {
      display: inline-block; background: rgba(108,140,255,0.06);
      color: var(--accent); padding: 0.25rem 0.65rem; border-radius: 4px;
      font-size: 0.78rem; font-weight: 500; margin-right: 0.4rem; margin-bottom: 0.4rem;
    }

    /* ── Buttons ── */
    .btn {
      display: inline-flex; align-items: center; gap: 0.5rem;
      padding: 0.7rem 1.5rem; border-radius: var(--radius-sm);
      font-size: 0.9rem; font-weight: 600; text-decoration: none;
      transition: all 0.25s; cursor: pointer; border: none;
    }
    .btn-primary { background: var(--accent); color: #fff; }
    .btn-primary:hover { opacity: 0.9; transform: translateY(-2px); box-shadow: 0 8px 30px var(--accent-glow); }
    .btn-outline { border: 1px solid var(--border); color: var(--text); background: transparent; }
    .btn-outline:hover { border-color: var(--accent); color: var(--accent); }

    /* ── Project card ── */
    .project-card { text-decoration: none; display: block; }
    .project-thumb {
      width: 100%; height: 200px; border-radius: var(--radius-sm);
      background: linear-gradient(135deg, #1a1a20, #22222a);
      margin-bottom: 1rem; display: flex; align-items: center; justify-content: center;
      border: 1px solid var(--border); overflow: hidden;
    }
    .project-thumb .icon { font-size: 3rem; opacity: 0.3; }
    .project-card h3 { color: #fff; transition: color 0.2s; }
    .project-card:hover h3 { color: var(--accent); }
    .project-card p { font-size: 0.85rem; color: var(--text-muted); }

    /* ── Footer CTA ── */
    .cta-section {
      text-align: center; padding: 5rem 0;
      border-top: 1px solid var(--border);
    }
    .cta-section h2 { font-size: 2.5rem; margin-bottom: 0.5rem; }
    .cta-section p { margin-bottom: 2rem; }

    /* ── Bottom bar ── */
    .bottom-bar {
      border-top: 1px solid var(--border); padding: 1rem 0;
      display: flex; justify-content: space-between; align-items: center;
      font-size: 0.8rem; color: var(--text-muted);
    }
    .bottom-bar a { color: var(--text-muted); text-decoration: none; }
    .bottom-bar a:hover { color: var(--accent); }

    /* ── Responsive ── */
    @media (max-width: 768px) {
      h1 { font-size: 2.2rem; }
      h2 { font-size: 1.6rem; }
      .hero { flex-direction: column-reverse; gap: 2rem; }
      .hero-image { flex: none; }
      .hero-image-placeholder { width: 200px; height: 250px; }
      .hero-image-placeholder .initials { font-size: 3rem; }
      .grid-2, .grid-3, .grid-4 { grid-template-columns: 1fr; }
      .nav-links { gap: 1rem; }
      .nav-links a { font-size: 0.78rem; }
      section { padding: 3rem 0; }
    }
  </style>
</head>
<body>
  <div class="container">
    <nav>
      <a href="/" class="logo"><span>李</span>宗奇</a>
      <div class="nav-links">
        <a href="#about">关于 ABOUT</a>
        <a href="#works">作品 WORKS</a>
        <a href="#contact">联系 CONTACT</a>
      </div>
    </nav>
  </div>

  <main><slot /></main>

  <div class="container">
    <div class="bottom-bar">
      <span>© 2026 李宗奇</span>
      <a href="#contact">联系我 →</a>
    </div>
  </div>
</body>
</html>
