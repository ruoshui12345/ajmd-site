---
// 全局布局 — 导航 + 页脚
export interface Props {
  title?: string;
  description?: string;
}

const { title = 'AJMD | 财务×AI', description = 'AI+财务副业实践者' } = Astro.props;
---

<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <style>
      * { margin: 0; padding: 0; box-sizing: border-box; }
      body {
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Noto Sans SC", sans-serif;
        background: #0a0a0a;
        color: #e5e5e5;
        line-height: 1.7;
        min-height: 100vh;
      }
      nav {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 1.2rem 2rem;
        border-bottom: 1px solid #1a1a1a;
        max-width: 1000px;
        margin: 0 auto;
      }
      .logo { font-size: 1.3rem; font-weight: 700; color: #fff; text-decoration: none; letter-spacing: -0.5px; }
      .logo span { color: #ff6b6b; }
      .nav-links { display: flex; gap: 2rem; }
      .nav-links a { color: #888; text-decoration: none; font-size: 0.9rem; transition: color 0.2s; }
      .nav-links a:hover { color: #fff; }
      main { max-width: 1000px; margin: 0 auto; padding: 3rem 2rem; }
      footer {
        text-align: center;
        padding: 3rem 2rem;
        color: #555;
        font-size: 0.85rem;
        border-top: 1px solid #1a1a1a;
        max-width: 1000px;
        margin: 0 auto;
      }
      footer a { color: #888; text-decoration: none; }
      footer a:hover { color: #fff; }
      h1 { font-size: 2.5rem; font-weight: 800; color: #fff; margin-bottom: 1rem; line-height: 1.3; }
      h2 { font-size: 1.8rem; font-weight: 700; color: #fff; margin: 2.5rem 0 1rem; }
      h3 { font-size: 1.2rem; font-weight: 600; color: #ddd; margin: 1.5rem 0 0.8rem; }
      p { color: #999; margin-bottom: 1rem; }
      .highlight { color: #ff6b6b; }
      .tag { display: inline-block; background: #1a1a1a; color: #888; padding: 0.2rem 0.6rem; border-radius: 4px; font-size: 0.8rem; margin-right: 0.4rem; }
      .btn {
        display: inline-block; padding: 0.7rem 1.5rem; border-radius: 6px;
        font-size: 0.9rem; font-weight: 600; text-decoration: none; transition: all 0.2s; cursor: pointer;
      }
      .btn-primary { background: #ff6b6b; color: #fff; border: none; }
      .btn-primary:hover { background: #e05555; }
      .btn-outline { background: transparent; color: #fff; border: 1px solid #333; }
      .btn-outline:hover { border-color: #ff6b6b; color: #ff6b6b; }
      .card {
        background: #111; border: 1px solid #1a1a1a; border-radius: 8px; padding: 1.5rem;
        transition: border-color 0.2s;
      }
      .card:hover { border-color: #333; }
      .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; }
      .grid-3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 1.5rem; }
      @media (max-width: 768px) {
        .grid-2, .grid-3 { grid-template-columns: 1fr; }
        h1 { font-size: 1.8rem; }
        nav { padding: 1rem; }
        .nav-links { gap: 1rem; }
      }
      .blog-card { margin-bottom: 1.5rem; }
      .blog-card .date { color: #555; font-size: 0.85rem; }
      .blog-card h3 { margin-top: 0.3rem; }
      .blog-card h3 a { color: #fff; text-decoration: none; }
      .blog-card h3 a:hover { color: #ff6b6b; }
    </style>
  </head>
  <body>
    <nav>
      <a href="/" class="logo"><span>AJ</span>MD</a>
      <div class="nav-links">
        <a href="/">首页</a>
        <a href="/about">关于</a>
        <a href="/blog">博客</a>
        <a href="/products">产品</a>
        <a href="/contact">联系</a>
      </div>
    </nav>
    <main>
      <slot />
    </main>
    <footer>
      <p>© 2026 AJMD · 财务×AI · <a href="https://xiaohongshu.com" target="_blank">小红书</a></p>
    </footer>
  </body>
</html>
